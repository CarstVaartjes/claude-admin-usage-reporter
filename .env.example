# Admin API key from Claude Console > Settings > Organization > Admin API keys.
# Requires the organization `admin` role to create. Starts with sk-ant-admin...
# Docs: https://platform.claude.com/docs/en/manage-claude/admin-api
ANTHROPIC_ADMIN_KEY=sk-ant-admin-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Optional overrides:
# ANTHROPIC_API_BASE_URL=https://api.anthropic.com
# ANTHROPIC_VERSION=2023-06-01
# DEFAULT_MONTHS_BACK=6
# DATA_DIR=./data
